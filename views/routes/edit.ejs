<% layout("/layouts/boilerplate") %>

<div class="container mt-4">

<h2 class="mb-4">
    <i class="bi bi-pencil-square"></i>
    Edit Route
</h2>

<form
action="/routes/<%= route._id %>?_method=PUT"
method="POST">

    <input
    type="text"
    name="vehicleType"
    value="<%= route.vehicleType %>"
    class="form-control mb-3"
    placeholder="Vehicle Type"
    required>

    <input
    type="text"
    name="vehicleNumber"
    value="<%= route.vehicleNumber %>"
    class="form-control mb-3"
    placeholder="Vehicle Number"
    required>

    <input
    type="text"
    name="contactNumber"
    value="<%= route.contactNumber %>"
    class="form-control mb-3"
    placeholder="Contact Number"
    required>

    <input
    type="number"
    name="totalSeats"
    value="<%= route.totalSeats %>"
    class="form-control mb-3"
    placeholder="Total Seats"
    required>

    <input
    type="number"
    name="availableSeats"
    value="<%= route.availableSeats %>"
    class="form-control mb-4"
    placeholder="Available Seats"
    required>

    <h4 class="mb-3">
        Route Segments
    </h4>

    <div id="routesContainer">

        <% route.stops.forEach((stop)=>{ %>

        <div class="routeRow row align-items-end border rounded p-3 mb-3">

            <div class="col-md-3 mb-2">
                <label class="form-label">From</label>
                <input
                type="text"
                name="from[]"
                value="<%= stop.from %>"
                class="form-control"
                required>
            </div>

            <div class="col-md-3 mb-2">
                <label class="form-label">To</label>
                <input
                type="text"
                name="to[]"
                value="<%= stop.to %>"
                class="form-control"
                required>
            </div>

            <div class="col-md-2 mb-2">
                <label class="form-label">Fare</label>
                <input
                type="number"
                name="fare[]"
                value="<%= stop.fare %>"
                class="form-control"
                required>
            </div>

            <div class="col-md-2 mb-2">
                <label class="form-label">Arrival Time</label>
                  <input
                    type="text"
                    name="ArrivalTime[]"
                    value="<%= stop.arrivalTime %>"
                    class="form-control"
                    required>
            </div>

            <div class="col-md-2 mb-2 text-center">
                <button
                type="button"
                class="btn btn-danger removeRoute">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

        </div>

        <% }) %>

    </div>

    <button
    type="button"
    class="btn btn-primary mb-4"
    onclick="addRoute()">

        <i class="bi bi-plus-circle-fill"></i>
        Add Route

    </button>

    <br>

    <button
    type="submit"
    class="btn btn-success">

        <i class="bi bi-check-circle-fill"></i>
        Update Route

    </button>

    <a
    href="/driver/dashboard"
    class="btn btn-secondary">

        Cancel

    </a>

</form>

</div>

<script>

function addRoute(){

const container=document.getElementById("routesContainer");

container.insertAdjacentHTML("beforeend",`

<div class="routeRow row align-items-end border rounded p-3 mb-3">

<div class="col-md-3 mb-2">
<label class="form-label">From</label>
<input type="text" name="from[]" class="form-control" required>
</div>

<div class="col-md-3 mb-2">
<label class="form-label">To</label>
<input type="text" name="to[]" class="form-control" required>
</div>

<div class="col-md-2 mb-2">
<label class="form-label">Fare</label>
<input type="number" name="fare[]" class="form-control" required>
</div>

<div class="col-md-2 mb-2">
<label class="form-label">Arrival Time</label>
<input type="text" name="ArrivalTime[]" class="form-control" required>
</div>

<div class="col-md-2 mb-2 text-center">

<button
type="button"
class="btn btn-danger removeRoute">

<i class="bi bi-x-lg"></i>

</button>

</div>

</div>

`);

}

document.addEventListener("click",function(e){

if(e.target.closest(".removeRoute")){

const rows=document.querySelectorAll(".routeRow");

if(rows.length===1){

alert("At least one route segment is required.");

return;

}

e.target.closest(".routeRow").remove();

}

});

</script>