<% layout("/layouts/boilerplate") %>

<div class="container py-4">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <div class="card shadow-lg border-0">

                <div class="card-header bg-primary text-white">

                    <h2 class="mb-0">
                         Create Route
                    </h2>

                </div>

                <div class="card-body">

                    <form action="/routes" method="POST">

                        <div class="mb-3">

                            <label class="form-label">
                                Vehicle Type
                            </label>

                            <input
                                type="text"
                                name="vehicleType"
                                class="form-control"
                                placeholder="e.g. Sumo, Bus, Tempo"
                                required
                            >

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Vehicle Number
                            </label>

                            <input
                                type="text"
                                name="vehicleNumber"
                                class="form-control"
                                placeholder="JK01A1234"
                                required
                            >

                        </div>

                        <div class="mb-3">

                            <label class="form-label">
                                Contact Number
                            </label>

                            <input
                                type="text"
                                name="contactNumber"
                                class="form-control"
                                placeholder="Enter Phone Number"
                                required
                            >

                        </div>

                        <div class="mb-4">

                            <label class="form-label">
                                Total Seats
                            </label>

                            <input
                                type="number"
                                name="totalSeats"
                                class="form-control"
                                placeholder="Enter Seats"
                                required
                            >

                        </div>

                    <hr>

<h4 class="mb-3">
    <i class="bi bi-geo-alt-fill"></i>
    Route Locations
</h4>

<div id="locationContainer">

    <div class="locationRow row mb-3">

        <div class="col-md-10">

            <input
                type="text"
                class="form-control locationInput"
                placeholder="Enter Location"
                required>

        </div>

        <div class="col-md-2">

            <button
                type="button"
                class="btn btn-danger removeLocation w-100">

                <i class="bi bi-x-lg"></i>

            </button>

        </div>

    </div>

</div>

<div class="mb-3">

    <button
        type="button"
        class="btn btn-secondary"
        onclick="addLocation()">

        <i class="bi bi-plus-circle"></i>

        Add Location

    </button>

    <button
        type="button"
        class="btn btn-primary"
        onclick="generateRoutes()">

        <i class="bi bi-diagram-3"></i>

        Generate Combinations

    </button>

</div>

<hr>

<h4>
Generated Routes
</h4>

<div id="routesContainer"></div>

<br>

<button
type="submit"
class="btn btn-success w-100">

Create Route

</button>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>





<script>

function addLocation(){

    const container =
    document.getElementById("locationContainer");

    const html = `

    <div class="locationRow row mb-3">

        <div class="col-md-10">

            <input
                type="text"
                class="form-control locationInput"
                placeholder="Enter Location"
                required>

        </div>

        <div class="col-md-2">

            <button
                type="button"
                class="btn btn-danger removeLocation w-100">

                <i class="bi bi-x-lg"></i>

            </button>

        </div>

    </div>

    `;

    container.insertAdjacentHTML(
        "beforeend",
        html
    );

}

document.addEventListener("click",function(e){

    if(e.target.closest(".removeLocation")){

        const rows =
        document.querySelectorAll(".locationRow");

        if(rows.length===1){

            alert("Minimum one location required.");

            return;

        }

        e.target
        .closest(".locationRow")
        .remove();

    }

});


function generateRoutes() {

    const routesContainer =
    document.getElementById("routesContainer");

    if(routesContainer.children.length>0){

        if(!confirm("Generate again? Existing generated routes will be removed.")){
            return;
        }

    }

    routesContainer.innerHTML="";

    const inputs =
    document.querySelectorAll(".locationInput");

    let locations = [];

    inputs.forEach(input => {

        if (input.value.trim() !== "") {

            locations.push(input.value.trim());

        }

    });

    if (locations.length < 2) {

        alert("Please add at least 2 locations.");

        return;

    }

    for (let i = 0; i < locations.length - 1; i++) {

        for (let j = i + 1; j < locations.length; j++) {

            routesContainer.insertAdjacentHTML("beforeend", `

            <div class="generatedRoute card p-3 mb-3 shadow-sm">

                <div class="row">

                    <div class="col-md-3 mb-2">

                        <label>From</label>

                        <input
                            type="text"
                            name="from[]"
                            class="form-control"
                            value="${locations[i]}"
                            readonly>

                    </div>

                    <div class="col-md-3 mb-2">

                        <label>To</label>

                        <input
                            type="text"
                            name="to[]"
                            class="form-control"
                            value="${locations[j]}"
                            readonly>

                    </div>

                    <div class="col-md-2 mb-2">

                        <label>Fare</label>

                        <input
                            type="number"
                            name="fare[]"
                            class="form-control"
                            placeholder="Fare"
                            required>

                    </div>

                    <div class="col-md-2 mb-2">

                        <label>Arrival Time</label>

                        <input
                            type="text"
                            name="time[]"
                            class="form-control"
                            required>

                    </div>

                    <div class="col-md-2 mb-2 d-flex align-items-end">

                        <button
                            type="button"
                            class="btn btn-danger w-100 removeGenerated">

                            <i class="bi bi-x-lg"></i>

                        </button>

                    </div>

                </div>

            </div>

            `);

        }

    }

}

// Remove Generated Route
document.addEventListener("click", function (e) {

    if (e.target.closest(".removeGenerated")) {

        e.target
        .closest(".generatedRoute")
        .remove();

    }

});

</script>


